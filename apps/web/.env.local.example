# Set to "true" to load sub-apps from their individual dev servers (devUrl).
# Requires each sub-app dev server to be running first:
#   pnpm nx dev react-app    (http://localhost:4201)
#   pnpm nx dev angular-app  (http://localhost:4202)
#
# When unset or "false" (the default), sub-apps are served from pre-built
# assets in public/apps/ — no sub-app dev servers needed.
NEXT_PUBLIC_USE_DEV_URLS=false
